# OpenAI-compatible API 服务地址，例如 OpenAI 官方或第三方代理服务。
BASE_URL=https://tokendocker.com/v1

# API key。真实值只写入本地 .env，不要提交到 Git。
OPENAI_API_KEY=your-api-key-here

# 默认模型。兼容旧配置：未设置下面的细分模型时，会使用 MODEL_NAME。
MODEL_NAME=gpt-5.5

# 主聊天模型：用于普通对话、工具结果总结、文件内容总结等。
CHAT_MODEL_NAME=gpt-5.5

# 工具选择模型：用于根据用户输入选择 get_weather、web_search 等工具。
TOOL_SELECTOR_MODEL_NAME=gpt-5.5

# 意图分类模型：保留给旧 Intent Router 和检查脚本使用。
INTENT_MODEL_NAME=gpt-5.5

# 视觉/多模态模型：用于处理图片、截图、图表等输入。模型和服务必须支持图片输入。
VISION_MODEL_NAME=gpt-5.5

# Embedding 模型：用于后续 RAG 知识检索，把文本转换为向量。
EMBEDDING_MODEL_NAME=text-embedding-3-small

# 备用模型：主聊天模型失败时使用。留空表示不启用 fallback。
FALLBACK_MODEL_NAME=

# 模型请求超时时间，单位秒。
MODEL_TIMEOUT_SECONDS=60

# 模型请求失败后的最大重试次数。
MODEL_MAX_RETRIES=2

# 长期记忆本地存储路径。默认写到项目运行目录下的 .agent_memory.json。
MEMORY_FILE_PATH=.agent_memory.json

# 最多保留的长期记忆条数。
MEMORY_MAX_ITEMS=50
