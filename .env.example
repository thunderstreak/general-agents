# OpenAI-compatible API 服务地址，例如 OpenAI 官方或第三方代理服务。
BASE_URL=your-api-base-url-here

# API key。真实值只写入本地 .env，不要提交到 Git。
OPENAI_API_KEY=your-api-key-here

# 默认模型。兼容旧配置：未设置下面的细分模型时，会使用 MODEL_NAME。
MODEL_NAME=gpt-5.5

# 主聊天模型：用于普通对话、工具结果总结、文件内容总结等。
CHAT_MODEL_NAME=gpt-5.5

# 工具选择模型：用于根据用户输入选择 get_weather、web_search 等工具。
TOOL_SELECTOR_MODEL_NAME=gpt-5.5

# 视觉/多模态模型：用于处理图片、截图、图表等输入。模型和服务必须支持图片输入。
VISION_MODEL_NAME=gpt-5.5

# Embedding 模型：用于后续 RAG 知识检索，把文本转换为向量。
EMBEDDING_MODEL_NAME=text-embedding-3-small

# 备用模型：主聊天模型失败时使用。留空表示不启用 fallback。
FALLBACK_MODEL_NAME=

# 模型请求超时时间，单位秒。
MODEL_TIMEOUT_SECONDS=60

# 模型请求失败后的最大重试次数。
MODEL_MAX_RETRIES=2

# 单个 @文件输入允许解析的最大体积，单位 MB。超限会在进入模型前拦截。
MAX_FILE_SIZE_MB=10

# 长期记忆本地存储路径。默认写到项目运行目录下的 .agent_memory.json。
MEMORY_FILE_PATH=.agent_memory.json

# 最多保留的长期记忆条数。
MEMORY_MAX_ITEMS=50

# 是否开启自动上下文压缩。手动 /compact 不受此开关影响。
CONTEXT_COMPACT_ENABLED=true

# 当前会话消息数量达到该阈值时，在下一轮用户输入前自动压缩。
CONTEXT_COMPACT_MESSAGE_THRESHOLD=40

# 压缩后保留最近多少轮原始对话。
CONTEXT_COMPACT_KEEP_TURNS=4

# 会话摘要最大字符数。
CONTEXT_COMPACT_SUMMARY_MAX_CHARS=6000

# 当前模型上下文窗口大小，单位 tokens。默认按 1M token 窗口估算。
CONTEXT_WINDOW_TOKENS=1000000

# 为模型输出预留的 token 数，计算剩余输入空间时会扣除。
CONTEXT_RESERVED_OUTPUT_TOKENS=4096

# 上下文 token 估算使用的 tokenizer 模型名。留空时使用 CHAT_MODEL_NAME。
CONTEXT_TOKENIZER_MODEL=

# token 使用率达到该百分比时自动压缩。设为 0 可关闭 token 阈值触发。
CONTEXT_COMPACT_TOKEN_THRESHOLD_PERCENT=80

# 单轮编排最多允许进入 agent/tool 节点的次数，避免工具循环。
ORCHESTRATOR_MAX_STEPS=8

# 是否开启本地 RAG 知识检索。
RAG_ENABLED=true

# RAG 知识库根目录。文档 metadata 和 Chroma 向量索引默认都写到这里。
RAG_STORE_DIR=.agent_knowledge

# Chroma 向量索引持久化目录。
CHROMA_PERSIST_DIR=.agent_knowledge/chroma

# Chroma collection 名称。
CHROMA_COLLECTION_NAME=agent_knowledge

# RAG embedding 提供方。可选 huggingface 或 openai；本地 LM Studio/OpenAI-compatible 服务用 openai。
RAG_EMBEDDING_PROVIDER=huggingface

# RAG embedding 模型。provider=huggingface 时是本地模型名；provider=openai 时是服务端模型名。
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# RAG embedding OpenAI-compatible 服务地址。provider=openai 时生效，可单独指向本地 LM 服务。
RAG_EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1

# RAG embedding API key。provider=openai 时生效；本地服务不校验时可保留任意非空值。
RAG_EMBEDDING_API_KEY=not-needed

# 文本切分 chunk 大小和重叠长度。
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120

# 每次检索返回的最多 chunk 数量。
RAG_TOP_K=4

# 向量检索候选数量。候选会经过本地关键词加权 rerank 后再截取 RAG_TOP_K。
RAG_CANDIDATE_K=12

# RAG 本地关键词加权权重，用于 hybrid keyword boost。
RAG_KEYWORD_WEIGHT=0.2

# Tavily Search API key。web_search 工具使用 Tavily 作为唯一搜索引擎。
TAVILY_API_KEY=your-tavily-api-key-here

# Tavily 每次搜索最多返回的结果数量。
WEB_SEARCH_MAX_RESULTS=5

# Tavily 搜索深度，可选 basic 或 advanced。
WEB_SEARCH_SEARCH_DEPTH=basic

# 是否在 CLI 输出 trace、节点耗时、工具摘要和错误详情。
OUTPUT_DEBUG=false

# 是否开启 CLI 流式输出。默认开启；关闭后会等待整轮执行完成再输出。
CLI_STREAM=true

# 是否在流式输出时显示检索、工具调用、记忆更新等进度。
CLI_STREAM_PROGRESS=true

# 是否允许任务运行中按 Esc 取消当前任务。macOS/Linux 终端默认开启。
CLI_ESC_CANCEL=true

# CLI 输入历史文件。用于支持上下键查看历史输入。
CLI_INPUT_HISTORY_FILE=.agent_input_history

# 文件夹式历史会话存储目录。默认写到项目运行目录下的 .agent_sessions。
SESSION_STORE_DIR=.agent_sessions

# 是否在每轮对话后自动保存当前会话。
SESSION_AUTO_SAVE=true
